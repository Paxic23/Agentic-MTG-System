# Copy this file to api/.env and fill in local values.
# Never commit api/.env to GitHub.

# none | ollama | openai | openai_compatible
LLM_PROVIDER=none
LLM_ENABLE_DECK_COACH=false

# Model name depends on provider.
# Ollama examples: llama3.1:8b, mistral, qwen2.5:7b
# OpenAI examples: gpt-4.1-mini, gpt-4o-mini
LLM_MODEL=

# For Ollama from Docker on Windows/Mac, host.docker.internal usually reaches the host machine.
# For native local API execution, use http://localhost:11434/v1 instead.
LLM_BASE_URL=http://host.docker.internal:11434/v1

# For Ollama, this can be any placeholder value, for example "ollama".
# For external providers, put the real secret in api/.env only.
LLM_API_KEY=

LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_TOKENS=900
